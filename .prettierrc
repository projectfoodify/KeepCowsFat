{
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 120,
    "singleQuote": false,
    "jsxSingleQuote": true,
    "trailingComma": "es5",
    "semi": true,
    "bracketSpacing": true,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "overrides": [
        {
            "files": "package.json",
            "options": {
                "tabWidth": 2,
                "useTabs": false
            }
        },
        {
            "files": "*.svg",
            "options": {
                "parser": "html"
            }
        }
    ]
}
